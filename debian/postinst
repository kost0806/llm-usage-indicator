#!/bin/bash
set -e

case "$1" in
    configure)
        # Determine the real (non-root) user who invoked the install.
        REAL_USER=""
        if [ -n "${SUDO_USER:-}" ] && [ "${SUDO_USER}" != "root" ]; then
            REAL_USER="${SUDO_USER}"
        elif [ -n "${PKEXEC_UID:-}" ] && [ "${PKEXEC_UID}" != "0" ]; then
            REAL_USER=$(getent passwd "${PKEXEC_UID}" | cut -d: -f1)
        fi

        if [ -z "${REAL_USER}" ]; then
            echo ""
            echo "llm-usage-indicator: WARNING: Could not detect the installing user."
            echo "  Run the per-user setup manually:"
            echo "    bash /usr/share/llm-usage-indicator/install.sh"
            echo ""
            exit 0
        fi

        REAL_HOME=$(getent passwd "${REAL_USER}" | cut -d: -f6)
        REAL_UID=$(id -u "${REAL_USER}")
        XDG_RUNTIME_DIR="/run/user/${REAL_UID}"

        # Enable linger so user services survive without an active login session.
        loginctl enable-linger "${REAL_USER}" 2>/dev/null || true

        # If a user@UID systemd service exists, make sure the user session is running
        # so that systemctl --user commands inside install.sh work immediately.
        if systemctl is-active --quiet "user@${REAL_UID}.service" 2>/dev/null; then
            : # session already up
        elif systemctl cat "user@${REAL_UID}.service" >/dev/null 2>&1; then
            systemctl start "user@${REAL_UID}.service" 2>/dev/null || true
            sleep 1
        fi

        echo "llm-usage-indicator: Running setup for user '${REAL_USER}'..."
        if ! runuser -u "${REAL_USER}" -- \
            env HOME="${REAL_HOME}" \
                XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR}" \
                DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR}/bus" \
            bash /usr/share/llm-usage-indicator/install.sh; then
            echo ""
            echo "llm-usage-indicator: ERROR: Per-user setup failed (see above)."
            echo "  Removing package to restore a clean state..."
            echo ""
            # Schedule dpkg --purge to run after the current dpkg transaction finishes.
            #
            # Why this works:
            #   dpkg -i holds /var/lib/dpkg/lock (not lock-frontend, which is apt-only).
            #   The background subshell closes all inherited file descriptors (> 2) to
            #   release its inherited copy of dpkg's lock fd, then opens a fresh fd on
            #   the same file and blocks with flock until dpkg releases the lock.
            #   Once the lock is free the purge runs in a clean dpkg invocation.
            (
                # Close all inherited fds > 2 so we do not hold dpkg's lock fd ourselves.
                for _fd in $(ls /proc/self/fd 2>/dev/null); do
                    [ "$_fd" -gt 2 ] && eval "exec $_fd>&-" 2>/dev/null || true
                done
                # Open a fresh fd on /var/lib/dpkg/lock and block until dpkg releases it.
                exec 9>>/var/lib/dpkg/lock
                flock -w 60 9 2>/dev/null || true
                exec 9>&-
                SUDO_USER="${REAL_USER}" dpkg --purge llm-usage-indicator
            ) >/dev/null 2>&1 &
            disown
        fi
        ;;
esac
