#!/bin/bash
set -e

case "$1" in
    configure)
        # Determine the real (non-root) user who invoked the install.
        REAL_USER=""
        if [ -n "${SUDO_USER:-}" ] && [ "${SUDO_USER}" != "root" ]; then
            REAL_USER="${SUDO_USER}"
        elif [ -n "${PKEXEC_UID:-}" ] && [ "${PKEXEC_UID}" != "0" ]; then
            REAL_USER=$(getent passwd "${PKEXEC_UID}" | cut -d: -f1)
        fi

        if [ -z "${REAL_USER}" ]; then
            echo ""
            echo "llm-usage-indicator: WARNING: Could not detect the installing user."
            echo "  Run the per-user setup manually:"
            echo "    bash /usr/share/llm-usage-indicator/install.sh"
            echo ""
            exit 0
        fi

        REAL_HOME=$(getent passwd "${REAL_USER}" | cut -d: -f6)
        REAL_UID=$(id -u "${REAL_USER}")
        XDG_RUNTIME_DIR="/run/user/${REAL_UID}"

        echo "llm-usage-indicator: Running setup for user '${REAL_USER}'..."
        if ! runuser -u "${REAL_USER}" -- \
            env HOME="${REAL_HOME}" \
                XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR}" \
                DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR}/bus" \
            bash /usr/share/llm-usage-indicator/install.sh; then
            echo ""
            echo "llm-usage-indicator: WARNING: Per-user setup failed (see above)."
            echo "  Fix the issue, then run manually:"
            echo "    bash /usr/share/llm-usage-indicator/install.sh"
            echo ""
        fi
        ;;
esac
